
<div class="max-w-2xl mx-auto">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Crear Nuevo Ticket</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Describe tu problema detalladamente para que podamos ayudarte mejor.</p>
        </div>
        <a href="/tickets/dashboard" class="text-sm font-medium text-primary-600 hover:text-primary-800 dark:text-primary-400 dark:hover:text-primary-300 transition-colors">
            &larr; Volver
        </a>
    </div>

    <div class="bg-white dark:bg-gray-800 shadow-sm rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
        <form action="/tickets/create" method="POST" class="p-6 space-y-6" id="createTicketForm" novalidate>
            
            <!-- Asunto -->
            <div>
                <label for="title" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Asunto del Ticket</label>
                <div class="mt-1">
                    <input type="text" name="title" id="title" required
                        class="block w-full py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors"
                        placeholder="Ej. Problema de acceso al sistema VPN" maxlength="120">
                </div>
                <p class="mt-1 text-xs text-red-500 hidden" id="title-error"></p>
            </div>

            <!-- Categoría -->
            <div>
                <label for="category" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Categoría</label>
                <div class="mt-1">
                    <select id="category" name="category" required
                        class="block w-full py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors">
                        <option value="Hardware">Hardware (Equipos, Impresoras, Pantallas)</option>
                        <option value="Software">Software (Sistemas, Aplicaciones, Lentos)</option>
                        <option value="Redes">Redes e Internet (Wi-Fi, VPN, Conexión)</option>
                        <option value="Accesos">Accesos (Contraseñas, Permisos, Cuentas)</option>
                        <option value="Otro">Otro Problema</option>
                    </select>
                </div>
            </div>

            <!-- Prioridad -->
            <div>
                <label for="priority" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Prioridad</label>
                <div class="mt-1">
                    <select id="priority" name="priority"
                        class="block w-full py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors">
                        <option value="baja">Baja - Incidente menor, no afecta el trabajo diario</option>
                        <option value="media" selected>Media - Afecta el trabajo pero hay alternativas</option>
                        <option value="alta">Alta - Sistema caído, bloquea el trabajo por completo</option>
                    </select>
                </div>
            </div>

            <!-- Descripción -->
            <div>
                <label for="description" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Descripción Detallada</label>
                <div class="mt-1">
                    <textarea id="description" name="description" rows="5" required
                        class="block w-full py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white transition-colors placeholder-gray-400"
                        placeholder="Describe los pasos para reproducir el problema, mensajes de error, etc." maxlength="2000"></textarea>
                </div>
                <p class="mt-1 text-xs text-gray-400">Mínimo 15 caracteres. Sé específico para que el técnico pueda ayudarte.</p>
                <p class="mt-1 text-xs text-red-500 hidden" id="description-error"></p>
            </div>

            <div class="pt-4 border-t border-gray-200 dark:border-gray-700 flex justify-end">
                <button type="submit" class="inline-flex justify-center py-2 px-6 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors">
                    Enviar Ticket
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function hasRepeatedChars(str) {
        return /(.)\1{4,}/.test(str); // 5 or more of the same character in a row
    }

    function isValidTitle(title) {
        const t = title.trim();
        if (t.length < 5) return 'El asunto debe tener al menos 5 caracteres.';
        if (t.length > 120) return 'El asunto es demasiado largo.';
        if (hasRepeatedChars(t)) return 'El asunto tiene demasiados caracteres repetidos. Sé más descriptivo.';
        if (/^(.)\1+$/.test(t.replace(/\s/g,''))) return 'El asunto parece inválido. Describe el problema brevemente.';
        return null;
    }

    function isValidDescription(desc) {
        const d = desc.trim();
        if (d.length < 15) return 'La descripción debe tener al menos 15 caracteres.';
        if (hasRepeatedChars(d)) return 'La descripción tiene demasiados caracteres repetidos seguidos.';
        // Check if description is just numbers
        if (/^\d+$/.test(d.replace(/\s/g,''))) return 'La descripción no puede ser solo números.';
        return null;
    }

    document.getElementById('createTicketForm').addEventListener('submit', function(e) {
        let hasError = false;

        const title = document.getElementById('title').value;
        const titleErr = isValidTitle(title);
        const titleErrEl = document.getElementById('title-error');
        if (titleErr) {
            titleErrEl.textContent = titleErr;
            titleErrEl.classList.remove('hidden');
            hasError = true;
        } else {
            titleErrEl.classList.add('hidden');
        }

        const desc = document.getElementById('description').value;
        const descErr = isValidDescription(desc);
        const descErrEl = document.getElementById('description-error');
        if (descErr) {
            descErrEl.textContent = descErr;
            descErrEl.classList.remove('hidden');
            hasError = true;
        } else {
            descErrEl.classList.add('hidden');
        }

        if (hasError) e.preventDefault();
    });
</script>
